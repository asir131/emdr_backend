{
	"info": {
		"_postman_id": "change-password-001",
		"name": "Change Password Flow",
		"description": "Profile > Change Password এর complete test। Happy path + সব edge cases।",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Login (Get Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (pm.response.code === 200 && res.data?.session) {",
							"    pm.collectionVariables.set('accessToken', res.data.session.accessToken);",
							"    pm.collectionVariables.set('refreshToken', res.data.session.refreshToken);",
							"    console.log('✅ Login OK — token saved');",
							"    pm.test('Login successful', () => {",
							"        pm.expect(res.success).to.be.true;",
							"        pm.expect(res.data.session.accessToken).to.exist;",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"rakib@example.com\",\n  \"password\": \"Test@1234\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				},
				"description": "আগে login করুন। accessToken automatically save হবে।"
			},
			"response": []
		},
		{
			"name": "1. ✅ Change Password (Success)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"pm.test('Password changed successfully', () => {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"    pm.expect(res.success).to.be.true;",
							"    pm.expect(res.data.message).to.equal('Password updated successfully');",
							"    console.log('✅ Password changed — all sessions invalidated');",
							"    console.log('📧 Security email should be sent to user');",
							"});",
							"",
							"pm.test('Response has timestamp', () => {",
							"    pm.expect(res.meta.timestamp).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
				},
				"method": "PATCH",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"currentPassword\": \"Test@1234\",\n  \"newPassword\": \"NewPass@5678\",\n  \"confirmPassword\": \"NewPass@5678\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/profile/change-password",
					"host": ["{{baseUrl}}"],
					"path": ["api", "profile", "change-password"]
				},
				"description": "Password successfully change করুন। Security alert email যাবে।"
			},
			"response": []
		},
		{
			"name": "2. 🔄 Login With New Password",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (pm.response.code === 200) {",
							"    pm.collectionVariables.set('accessToken', res.data.session.accessToken);",
							"    pm.collectionVariables.set('refreshToken', res.data.session.refreshToken);",
							"    console.log('✅ Login with new password works');",
							"    pm.test('New password login successful', () => {",
							"        pm.expect(res.success).to.be.true;",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"rakib@example.com\",\n  \"password\": \"NewPass@5678\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				},
				"description": "নতুন password দিয়ে login করুন — confirm করুন যে password change হয়েছে।"
			},
			"response": []
		},
		{
			"name": "3. 🔄 Revert Back to Original Password",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Password reverted', () => {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"    console.log('✅ Password reverted to original for further testing');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
				},
				"method": "PATCH",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"currentPassword\": \"NewPass@5678\",\n  \"newPassword\": \"Test@1234\",\n  \"confirmPassword\": \"Test@1234\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/profile/change-password",
					"host": ["{{baseUrl}}"],
					"path": ["api", "profile", "change-password"]
				},
				"description": "Test শেষে original password এ ফিরে যান।"
			},
			"response": []
		},
		{
			"name": "── EDGE CASE TESTS ──────────────",
			"item": [
				{
					"name": "❌ Wrong Current Password (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Wrong current password rejected', () => {",
									"    pm.expect(pm.response.code).to.equal(400);",
									"    pm.expect(res.success).to.be.false;",
									"    pm.expect(res.error.field).to.equal('currentPassword');",
									"    console.log('✅ Correctly rejected wrong current password');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"WrongPass@999\",\n  \"newPassword\": \"NewPass@5678\",\n  \"confirmPassword\": \"NewPass@5678\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				},
				{
					"name": "❌ New Password Same as Current (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Same password rejected', () => {",
									"    pm.expect(pm.response.code).to.equal(400);",
									"    pm.expect(res.success).to.be.false;",
									"    console.log('✅ Correctly rejected — same as current password');",
									"    console.log('Error:', res.error.message);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"Test@1234\",\n  \"newPassword\": \"Test@1234\",\n  \"confirmPassword\": \"Test@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				},
				{
					"name": "❌ Confirm Password Mismatch (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Confirm mismatch rejected', () => {",
									"    pm.expect(pm.response.code).to.equal(400);",
									"    pm.expect(res.success).to.be.false;",
									"    pm.expect(res.error.field).to.equal('confirmPassword');",
									"    console.log('✅ Correctly rejected — passwords do not match');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"Test@1234\",\n  \"newPassword\": \"NewPass@5678\",\n  \"confirmPassword\": \"DifferentPass@999\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				},
				{
					"name": "❌ Weak New Password (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Weak password rejected', () => {",
									"    pm.expect(pm.response.code).to.equal(400);",
									"    pm.expect(res.success).to.be.false;",
									"    console.log('✅ Correctly rejected weak password');",
									"    console.log('Error:', res.error.message);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"Test@1234\",\n  \"newPassword\": \"weak\",\n  \"confirmPassword\": \"weak\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				},
				{
					"name": "❌ Missing Fields (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Missing fields rejected', () => {",
									"    pm.expect(pm.response.code).to.equal(400);",
									"    pm.expect(res.success).to.be.false;",
									"    console.log('✅ Correctly rejected missing fields');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"Test@1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				},
				{
					"name": "❌ No Token (401)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Blocked without token', () => {",
									"    pm.expect(pm.response.code).to.equal(401);",
									"    console.log('✅ Correctly blocked — no auth token');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"currentPassword\": \"Test@1234\",\n  \"newPassword\": \"NewPass@5678\",\n  \"confirmPassword\": \"NewPass@5678\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/profile/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "profile", "change-password"]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl",      "value": "http://localhost:5005", "type": "string" },
		{ "key": "accessToken",  "value": "", "type": "string" },
		{ "key": "refreshToken", "value": "", "type": "string" }
	]
}
