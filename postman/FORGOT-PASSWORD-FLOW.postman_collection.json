{
	"info": {
		"_postman_id": "forgot-password-flow",
		"name": "Forgot Password Flow - Complete",
		"description": "Complete forgot password flow:\n\n1. Send OTP to email\n2. Verify OTP and get access token\n3. Reset password using access token",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Step 1 - Send OTP",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response has correct structure', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(true);",
							"    pm.expect(response.data).to.have.property('message');",
							"    pm.expect(response.data).to.have.property('_dev_otp');",
							"});",
							"",
							"pm.test('Save OTP for next step', function () {",
							"    const response = pm.response.json();",
							"    pm.collectionVariables.set('recoveryOtp', response.data._dev_otp);",
							"    console.log('✅ Recovery OTP saved:', response.data._dev_otp);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"testuser@myemdr.com\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Step 1: Send recovery OTP to email\n\nRequest: {\"email\": \"testuser@myemdr.com\"}\nResponse: {\"message\": \"OTP sent to your email for password reset.\", \"_dev_otp\": \"123456\"}"
		},
		{
			"name": "Step 2 - Verify OTP",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response has correct structure', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(true);",
							"    pm.expect(response.data).to.have.property('message');",
							"    pm.expect(response.data).to.have.property('accessToken');",
							"});",
							"",
							"pm.test('Save access token for password reset', function () {",
							"    const response = pm.response.json();",
							"    pm.collectionVariables.set('resetAccessToken', response.data.accessToken);",
							"    console.log('✅ Access token saved for password reset');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"testuser@myemdr.com\",\n  \"otp\": \"{{recoveryOtp}}\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Step 2: Verify OTP and get access token\n\nRequest: {\"email\": \"testuser@myemdr.com\", \"otp\": \"123456\"}\nResponse: {\"message\": \"OTP verified successfully. You can now reset your password.\", \"accessToken\": \"...\"}"
		},
		{
			"name": "Step 3 - Reset Password",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Password reset successful', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(true);",
							"    pm.expect(response.data.message).to.include('Password reset successfully');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{resetAccessToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"newPassword\": \"NewSecurePass456!\",\n  \"confirmPassword\": \"NewSecurePass456!\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/recover-account",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "recover-account"]
				}
			},
			"description": "Step 3: Reset password using access token\n\nHeaders: Authorization: Bearer <accessToken>\nRequest: {\"newPassword\": \"NewSecurePass456!\", \"confirmPassword\": \"NewSecurePass456!\"}\nResponse: {\"message\": \"Password reset successfully.\"}"
		},
		{
			"name": "ERROR - Invalid Email",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 400', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test('Error response format', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(false);",
							"    pm.expect(response.error.code).to.equal('VALIDATION_ERROR');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"invalid-email-format\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Test error handling for invalid email format"
		},
		{
			"name": "ERROR - Invalid OTP",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 400', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test('Error for invalid OTP', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(false);",
							"    pm.expect(response.error.code).to.equal('OTP_INVALID');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"testuser@myemdr.com\",\n  \"otp\": \"000000\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Test error handling for invalid OTP"
		},
		{
			"name": "ERROR - User Not Found",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 404', function () {",
							"    pm.response.to.have.status(404);",
							"});",
							"",
							"pm.test('Error for user not found', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(false);",
							"    pm.expect(response.error.code).to.equal('USER_NOT_FOUND');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"nonexistent@example.com\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Test error handling for user not found"
		},
		{
			"name": "ERROR - OTP Expired",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 400', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test('Error for expired OTP', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.equal(false);",
							"    pm.expect(response.error.code).to.equal('OTP_EXPIRED');",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"testuser@myemdr.com\",\n  \"otp\": \"123456\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/send-verification-otp",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "send-verification-otp"]
				}
			},
			"description": "Test error handling for expired OTP (after 10 minutes)"
		}
	],
	"variable": [
		{
			"key": "recoveryOtp",
			"value": "",
			"type": "string"
		},
		{
			"key": "resetAccessToken",
			"value": "",
			"type": "string"
		}
	]
}
