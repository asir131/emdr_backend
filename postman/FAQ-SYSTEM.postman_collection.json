					"request": {
						"auth": {"type": "bearer","bearer": [{"key": "token","value": "{{adminToken}}","type": "string"}]},
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {"mode": "raw","raw": "{\n  \"question\": \"Hi?\",\n  \"answer\": \"This answer is long enough to pass validation.\"\n}"},
						"url": {"raw": "{{baseUrl}}/api/faq","host": ["{{baseUrl}}"],"path": ["api","faq"]}
