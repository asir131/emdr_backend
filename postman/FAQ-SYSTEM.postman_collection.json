{
	"info": {
		"_postman_id": "faq-system-001",
		"name": "FAQ System — Full Test",
		"description": "FAQ CRUD — Create, Get, Update, Reorder, Delete + Edge Cases.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
