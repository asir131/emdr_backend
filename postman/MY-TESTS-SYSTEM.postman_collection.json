{
  "info": {
    "name": "My Tests System - Complete CRUD",
    "description": "Production-level Category and Items management system with full CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "itemId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "1. Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('categoryId', response.data._id);",
                  "    pm.environment.set('categoryId', response.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Weekly Health Tests\",\n  \"description\": \"My weekly health and wellness tests\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories"]
            },
            "description": "Create a new test category"
          },
          "response": []
        },
        {
          "name": "2. List All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Get all categories with pagination"
          },
          "response": []
        },
        {
          "name": "3. Get Category by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}"]
            },
            "description": "Get a single category by ID"
          },
          "response": []
        },
        {
          "name": "4. Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Updated Category Name\",\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}"]
            },
            "description": "Update category details"
          },
          "response": []
        },
        {
          "name": "5. Get Category Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}/stats",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}", "stats"]
            },
            "description": "Get category statistics (total items, items by day, etc.)"
          },
          "response": []
        },
        {
          "name": "6. Delete Category",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}"]
            },
            "description": "Delete category and all its items"
          },
          "response": []
        }
      ],
      "description": "Category management endpoints"
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "1. Create Item in Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('itemId', response.data._id);",
