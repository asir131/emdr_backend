                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"Blood Pressure Check\",\n  \"description\": \"Check BP in the morning before breakfast\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}/items",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}", "items"]
            },
            "description": "Create a new item in a category. Day will be auto-calculated from creation date (Sunday-Saturday). You can also manually specify the day."
          },
          "response": []
        },
        {
          "name": "2. List Items in Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/categories/{{categoryId}}/items?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "categories", "{{categoryId}}", "items"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "day",
                  "value": "Monday",
                  "disabled": true
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Get all items in a specific category"
          },
          "response": []
        },
        {
          "name": "3. List All User Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/items?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "items"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "day",
                  "value": "Monday",
                  "disabled": true
                }
              ]
            },
            "description": "Get all items across all categories for the user"
          },
          "response": []
        },
        {
          "name": "4. Get Item by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "items", "{{itemId}}"]
            },
            "description": "Get a single item by ID"
          },
          "response": []
        },
        {
          "name": "5. Update Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"Updated Item Name\",\n  \"day\": \"Tuesday\",\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/my-tests/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "items", "{{itemId}}"]
            },
            "description": "Update item details"
          },
          "response": []
        },
        {
          "name": "6. Delete Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-tests/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["my-tests", "items", "{{itemId}}"]
            },
            "description": "Delete an item"
          },
          "response": []
        }
      ],
      "description": "Item management endpoints"
    },
