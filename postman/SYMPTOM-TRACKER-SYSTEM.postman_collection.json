{
  "info": {
    "name": "SYMPTOM-TRACKER-SYSTEM",
    "_postman_id": "symptom-tracker-full-collection",
    "description": "Complete Symptom Tracker API — Admin config CRUD + User submission + History + Trend + Admin analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api", "type": "string" },
    { "key": "adminToken",   "value": "PASTE_ADMIN_JWT_HERE",      "type": "string" },
    { "key": "userToken",    "value": "PASTE_USER_JWT_HERE",       "type": "string" },
    { "key": "trackerType",  "value": "anxiety",                   "type": "string" },
    { "key": "submissionId", "value": "",                          "type": "string" }
  ],
  "item": [

    {
      "name": "01 — Admin: Config CRUD",
      "description": "Admin creates and manages tracker definitions. Run 'Create Anxiety Config' once to seed the DB.",
      "item": [

        {
          "name": "Create Anxiety Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success true', () => pm.expect(res.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"name\": \"Anxiety\",\n  \"description\": \"A brief check-in on how anxiety has shown up in your body, mind, and daily life over the past week.\",\n  \"items\": [\n    { \"text\": \"My body has felt activated when there was no real reason for it (heart, breath, muscles, gut).\", \"reverse\": false },\n    { \"text\": \"I have noticed a background hum of unease that wouldn't lift.\", \"reverse\": false },\n    { \"text\": \"My mind has jumped ahead to things that could go wrong.\", \"reverse\": false },\n    { \"text\": \"I have changed plans or skipped things because of how I expected to feel.\", \"reverse\": false },\n    { \"text\": \"I have struggled to drop into rest, even when the day was done.\", \"reverse\": false },\n    { \"text\": \"My nervous system has felt steady and at ease.\", \"reverse\": true },\n    { \"text\": \"I have felt braced or guarded without knowing what for.\", \"reverse\": false },\n    { \"text\": \"I have noticed it taking longer to recover from small stresses.\", \"reverse\": false },\n    { \"text\": \"My anxiety has spilled into work, study, or daily tasks.\", \"reverse\": false },\n    { \"text\": \"My anxiety has shaped how I show up with the people around me.\", \"reverse\": false }\n  ],\n  \"options\": [\n    { \"value\": 0, \"label\": \"Never\" },\n    { \"value\": 1, \"label\": \"Rarely\" },\n    { \"value\": 2, \"label\": \"Sometimes\" },\n    { \"value\": 3, \"label\": \"Often\" },\n    { \"value\": 4, \"label\": \"Almost always\" }\n  ],\n  \"bands\": [\n    { \"max\": 9,  \"label\": \"Minimal\",  \"description\": \"Few symptoms of anxiety reported in the past week. This level of activation is within the range commonly experienced in everyday life.\" },\n    { \"max\": 17, \"label\": \"Mild\",     \"description\": \"Some symptoms of anxiety present. These may be noticeable to you but are unlikely to be substantially disrupting daily life. Worth tracking week to week as you work through the programme.\" },\n    { \"max\": 25, \"label\": \"Moderate\", \"description\": \"A meaningful pattern of anxiety symptoms over the past week. The EMDR work in this programme is well-suited to addressing the roots of anxiety. Track this score over time to notice changes.\" },\n    { \"max\": 32, \"label\": \"Marked\",   \"description\": \"Substantial anxiety symptoms with likely impact on functioning and wellbeing. Continue with the programme but pace yourself, and consider whether speaking to your GP or a mental health professional might offer useful additional support.\" },\n    { \"max\": 40, \"label\": \"Severe\",   \"description\": \"A high level of anxiety symptoms with significant impact across multiple areas of life. At this level, additional support is recommended alongside the programme — please consider speaking to your GP or a qualified mental health professional.\" }\n  ],\n  \"alerts\": [],\n  \"stemKey\": null,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs"]
            },
            "description": "Creates the Anxiety tracker config in DB. Run this ONCE. Returns 409 if already exists."
          }
        },

        {
          "name": "List All Configs (Admin — incl. inactive)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs"]
            },
            "description": "Returns all configs including inactive ones. Admin only."
          }
        },

        {
          "name": "Update Config (partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"isActive\": true,\n  \"description\": \"Updated: A brief check-in on how anxiety has shown up over the past week.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs", "{{trackerType}}"]
            },
            "description": "Partial update — only send fields you want to change."
          }
        },

        {
          "name": "Delete Config",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs", "{{trackerType}}"]
            },
            "description": "Permanently deletes the config. Clears Redis cache."
          }
        }

      ]
    },

    {
      "name": "02 — Public: Load Config (no auth)",
      "description": "App calls these to render the tracker UI. No token needed.",
      "item": [

        {
          "name": "List All Active Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "configs"]
            },
            "description": "Returns all isActive=true configs. Cached in Redis for 30 min."
          }
        },

        {
          "name": "Get Anxiety Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "configs", "{{trackerType}}"]
            },
            "description": "Returns the full config for 'anxiety' — items, options, bands, alerts. App uses this to render the HTML tracker."
          }
        }

      ]
    },

    {
      "name": "03 — User: Submit Answers",
      "description": "User submits raw answers. Server scores everything — never trust client score.",
      "item": [

        {
          "name": "Submit — Moderate score (21/40)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('has submissionId', () => pm.expect(res.data.submissionId).to.exist);",
                  "pm.test('has totalScore', () => pm.expect(res.data.totalScore).to.be.a('number'));",
                  "if (res.success && res.data.submissionId) {",
                  "  pm.collectionVariables.set('submissionId', res.data.submissionId);",
                  "  console.log('submissionId saved:', res.data.submissionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [3, 2, 3, 1, 2, 1, 2, 3, 2, 2],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "answers[] must have exactly 10 items (0–4 each).\nItem 6 (index 5) is reverse-scored: answer 1 → scored 3.\nExpected: totalScore=21, band=Moderate"
          }
        },

        {
          "name": "Submit — Minimal score (2/40)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [0, 0, 1, 0, 0, 4, 0, 0, 1, 0],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "Item 6 reverse: answer 4 → scored 0. Expected: totalScore=2, band=Minimal"
          }
        },

        {
          "name": "Submit — Severe score (40/40)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [4, 4, 4, 4, 4, 0, 4, 4, 4, 4],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "Item 6 reverse: answer 0 → scored 4. Expected: totalScore=40, band=Severe"
          }
        },

        {
          "name": "Submit — With stemValue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [2, 2, 2, 1, 2, 2, 1, 2, 1, 1],\n  \"stemValue\": \"work presentations\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "stemValue is used when the tracker has a focus identifier (stemKey != null). Saved with submission."
          }
        },

        {
          "name": "Submit — Validation error (wrong answer count)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [1, 2, 3],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "Should return 400 — Expected 10 answers, got 3."
          }
        },

        {
          "name": "Submit — Validation error (answer out of range)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [0, 0, 0, 0, 0, 99, 0, 0, 0, 0],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "Should return 400 — Answer at index 5 must be between 0 and 4."
          }
        }

      ]
    },

    {
      "name": "04 — User: History & Progress",
      "description": "View past submissions, trends, and latest scores.",
      "item": [

        {
          "name": "Get History — all trackers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Paginated list of all submissions for the logged-in user. itemScores excluded for brevity."
          }
        },

        {
          "name": "Get History — anxiety only",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history?trackerType=anxiety&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history"],
              "query": [
                { "key": "trackerType", "value": "anxiety" },
                { "key": "page",        "value": "1" },
                { "key": "limit",       "value": "20" }
              ]
            }
          }
        },

        {
          "name": "Get Single Submission Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history/{{submissionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history", "{{submissionId}}"]
            },
            "description": "Returns full submission including itemScores. Returns 403 if submissionId belongs to another user."
          }
        },

        {
          "name": "Get Trend — anxiety (last 10)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/trend?trackerType=anxiety&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "trend"],
              "query": [
                { "key": "trackerType", "value": "anxiety" },
                { "key": "limit",       "value": "10" }
              ]
            },
            "description": "Returns last N submissions in chronological order (oldest first). Use for chart rendering."
          }
        },

        {
          "name": "Get Latest — all tracker types",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/latest",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "latest"]
            },
            "description": "Returns the most recent submission for each tracker type the user has completed."
          }
        },

        {
          "name": "Get Latest — anxiety only",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/latest?trackerType=anxiety",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "latest"],
              "query": [
                { "key": "trackerType", "value": "anxiety" }
              ]
            }
          }
        }

      ]
    },

    {
      "name": "05 — Admin: Submissions & Analytics",
      "description": "Admin views all user submissions and aggregate stats.",
      "item": [

        {
          "name": "List All Submissions (paginated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/submissions?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "submissions"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "All submissions across all users. Populates userId with name + email."
          }
        },

        {
          "name": "List Submissions — filter by trackerType",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/submissions?trackerType=anxiety&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "submissions"],
              "query": [
                { "key": "trackerType", "value": "anxiety" },
                { "key": "page",        "value": "1" },
                { "key": "limit",       "value": "20" }
              ]
            }
          }
        },

        {
          "name": "List Submissions — filter by userId",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/submissions?userId=PASTE_USER_OBJECT_ID",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "submissions"],
              "query": [
                { "key": "userId", "value": "PASTE_USER_OBJECT_ID" }
              ]
            }
          }
        },

        {
          "name": "Get Stats (aggregate per tracker type)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/stats",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "stats"]
            },
            "description": "Returns per-tracker: totalCount, avgScore, lastSubmitted, bandBreakdown (how many users in each severity band)."
          }
        }

      ]
    }

  ]
}
