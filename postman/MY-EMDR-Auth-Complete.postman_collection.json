			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"test@example.com\",\n  \"password\": \"weak\",\n  \"confirmPassword\": \"weak\"\n}"
				},
				"url": {
					"raw": "http://localhost:5005/api/auth/signup",
					"protocol": "http",
					"host": ["localhost"],
					"port": "5005",
					"path": ["api", "auth", "signup"]
				}
			},
			"description": "Test error handling for weak password"
		},
		{
