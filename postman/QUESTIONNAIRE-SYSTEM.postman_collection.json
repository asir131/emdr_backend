	"item": [
		{
			"name": "── SETUP ────────────────────────────",
			"item": [
				{
					"name": "0. User Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const r = pm.response.json();",
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set('userToken', r.data.session.accessToken);",
									"    pm.collectionVariables.set('userId', r.data.user.id);",
									"    console.log('✅ User token saved');",
									"    console.log('👤 User ID:', r.data.user.id);",
									"    pm.test('Login OK', () => pm.expect(r.success).to.be.true);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "⚠️ Change email/password to a real user. Token auto-saved."
					},
					"response": []
				}
			]
		},
