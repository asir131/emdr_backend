# Server Configuration
NODE_ENV=development
PORT=5005

DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/my_emdr?appName=my_emdr


JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-secure
JWT_EXPIRES_IN=7d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@myemdr.com
EMAIL_FROM_NAME=MY EMDR

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (required for caching + notification queue)
REDIS_URL=redis://localhost:6379

# CORS (production only — comma separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY=your-private-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Admin Seed (used by: npm run seed:admin)
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@myemdr.com
ADMIN_PASSWORD=Admin@123456

# Cloudinary (profile picture upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
