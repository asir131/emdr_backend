# Server Configuration
NODE_ENV=development
PORT=5005

# MongoDB Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?appName=dbname
# Replace with your MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/my_emdr?appName=my_emdr

# Security
# Generate a secure random string (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-secure
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@myemdr.com
EMAIL_FROM_NAME=MY EMDR

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
